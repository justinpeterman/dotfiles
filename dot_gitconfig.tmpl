[user]
  name = {{ .name }}
  email = {{ .email }}

[github]
  user = {{ .github_user }}

[core]
  excludesfile = ~/.gitignore_global

[init]
  defaultBranch = main

[pull]
  rebase = true

[push]
  autoSetupRemote = true

[fetch]
  prune = true

[url "git@github.com:"]
  insteadOf = https://github.com/
